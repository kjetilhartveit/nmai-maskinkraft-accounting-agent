
# Session cookie from https://app.ainm.no (JWT, ~7-day TTL).
# How to get: Sign in at https://app.ainm.no via Google, then extract
# the "access_token" cookie from DevTools → Application → Cookies.
# The JWT exp claim shows when it expires. Run `pnpm submit` to check.
# To refresh: sign in again and copy the new cookie value.
AINM_ACCESS_TOKEN=

# Sandbox (get from https://app.ainm.no/submit/tripletex → "Get Sandbox Account")
SANDBOX_API_URL=
SANDBOX_SESSION_TOKEN=

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.5-flash

# Archived: OpenRouter (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=